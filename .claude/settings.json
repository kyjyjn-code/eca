{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "WebSearch",
      "WebFetch",
      "Bash",
      "PowerShell"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(rm -rf *)",
      "Bash(rmdir *)",
      "Bash(git reset --hard*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git clean *)",
      "Bash(git filter-branch*)",
      "Bash(shutdown*)",
      "Bash(mkfs*)",
      "Bash(:(){*)",
      "PowerShell(Remove-Item*)",
      "PowerShell(rm *)",
      "PowerShell(rmdir *)",
      "PowerShell(del *)",
      "PowerShell(erase *)",
      "PowerShell(rd *)",
      "PowerShell(Clear-Content*)",
      "PowerShell(Remove-ItemProperty*)",
      "PowerShell(git reset --hard*)",
      "PowerShell(git push --force*)",
      "PowerShell(git push -f*)",
      "PowerShell(git clean *)",
      "PowerShell(git filter-branch*)",
      "PowerShell(Stop-Computer*)",
      "PowerShell(Restart-Computer*)",
      "PowerShell(shutdown*)",
      "PowerShell(Format-Volume*)",
      "PowerShell(Clear-Disk*)",
      "PowerShell(reg delete*)",
      "PowerShell(Remove-Item -Recurse -Force*)"
    ]
  }
}
