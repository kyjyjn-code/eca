      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "WebSearch",
      "WebFetch",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(mkdir *)",
      "Bash(ls*)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(git status*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git init*)",
      "Bash(git remote*)",
      "Bash(git push*)",
      "PowerShell(node *)",
      "PowerShell(npm *)",
      "PowerShell(npx *)",
      "PowerShell(New-Item -ItemType Directory*)",
      "PowerShell(Get-ChildItem*)",
      "PowerShell(Get-Content*)",
      "PowerShell(Test-Path*)",
      "PowerShell(git status*)",
      "PowerShell(git add*)",
      "PowerShell(git commit*)",
      "PowerShell(git log*)",
      "PowerShell(git diff*)",
      "PowerShell(git branch*)",
      "PowerShell(git checkout*)",
      "PowerShell(git init*)",
      "PowerShell(git remote*)",
